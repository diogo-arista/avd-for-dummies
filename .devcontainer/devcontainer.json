{
  "name": "AVD Lab",

  // Build from a minimal Dockerfile that pre-creates the clab_admins group.
  // VS Code server starts with process-level groups fixed at launch; usermod
  // in postCreate.sh runs too late for extension activation. The Dockerfile
  // contains zero apt-get / network calls so it builds cleanly in Codespaces.
  "build": {
    "dockerfile": "Dockerfile"
  },

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true,
      "dockerDashComposeVersion": "none"
    }
  },
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.vscode-yaml",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "wholroyd.jinja",
        "srl-labs.vscode-containerlab"
      ],
      "settings": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.rulers": [120],
        "[yaml]": {
          "editor.defaultFormatter": "redhat.vscode-yaml"
        },
        "yaml.schemas": {
          "https://avd.arista.com/schema/avd.json": [
            "inventory/group_vars/**/*.yml",
            "codespaces/inventory/group_vars/**/*.yml"
          ]
        }
      }
    }
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "32gb"
  },
  "remoteUser": "vscode"
}
